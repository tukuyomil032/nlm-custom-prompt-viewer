{
  "name": "nlm-custom-prompt-viewer",
  "version": "0.1.0",
  "description": "CLI to recover Studio custom prompts from NotebookLM artifacts",
  "type": "module",
  "bin": {
    "nlm-prompt": "./dist/index.js",
    "nlm": "./dist/index.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "keywords": [
    "notebooklm",
    "cli",
    "prompt",
    "typescript",
    "custom-prompt",
    "google",
    "AI",
    "LLM",
    "language-model"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gradient-string": "^3.0.0",
    "lefthook": "^2.1.8",
    "notebooklm-sdk": "^0.2.0",
    "string-width": "^8.2.1"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.13.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "author": "tukuyomil032",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tukuyomil032/nlm-custom-prompt-viewer.git"
  },
  "bugs": {
    "type": "git",
    "url": "git+https://github.com/tukuyomil032/nlm-custom-prompt-viewer.git/issues"
  },
  "homepage": "https://github.com/tukuyomil032/nlm-custom-prompt-viewer#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}

{
  "name": "nlm-custom-prompt-viewer",
  "version": "0.0.1",
  "description": "CLI to recover Studio custom prompts from NotebookLM artifacts",
  "keywords": [
    "AI",
    "LLM",
    "cli",
    "custom-prompt",
    "google",
    "language-model",
    "notebooklm",
    "prompt",
    "typescript"
  ],
  "homepage": "https://github.com/tukuyomil032/nlm-custom-prompt-viewer#readme",
  "bugs": {
    "url": "git+https://github.com/tukuyomil032/nlm-custom-prompt-viewer.git/issues",
    "type": "git"
  },
  "license": "MIT",
  "author": "tukuyomil032",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tukuyomil032/nlm-custom-prompt-viewer.git"
  },
  "bin": {
    "nlmv": "./dist/index.js",
    "nlm-prompt": "./dist/index.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "dev": "bun --watch src/index.ts",
    "test": "bunx vitest run",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "fmt": "oxfmt --check src tests",
    "fmt:fix": "oxfmt src tests",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix",
    "ci": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gradient-string": "^3.0.0",
    "lefthook": "^2.1.8",
    "notebooklm-sdk": "^0.2.0",
    "playwright": "^1.60.0",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.13.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
